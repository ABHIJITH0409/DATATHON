{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Launch Dashboard + Agents",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "▶ Dashboard Only",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/dashboard/dashboard.py",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "▶ Setup Database",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/db/setup.py",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "▶ Seed Database",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/db/seed.py",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
